# Harmony OS generated artifacts and secrets (do NOT commit)
*.hap
ohos/oh_modules/
ohos/entry/oh_modules/
ohos/node_modules/
ohos/har/
ohos/.hvigor/
# ohos/package.json and oh-package-lock.json5 are regenerated by flutter/ohpm from
# the SDK path, so they must NOT be committed (machine-specific).
ohos/package.json
ohos/package-lock.json
ohos/entry/oh-package-lock.json5
ohos/signing/
ohos/entry/build/
ohos/build/
# rawfile/flutter_assets are generated Flutter build outputs.
ohos/entry/src/main/resources/rawfile/

*.apk
*.deb
*.app
