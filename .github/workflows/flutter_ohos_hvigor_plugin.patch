@@ -1,4 +1,20 @@
+// Patch: hvigor 5.8.9 removed appContext.getOverrides()/setOverrides()
+// Workaround: inject overrides directly into oh-package.json5
+import * as fs from 'fs';
+import * as path from 'path';
+
+function injectOverrides(appContext: any) {
+  const projectDir = appContext.projectDir || process.cwd();
+  const ohPackagePath = path.join(projectDir, 'ohos', 'oh-package.json5');
+  if (fs.existsSync(ohPackagePath)) {
+    const content = fs.readFileSync(ohPackagePath, 'utf8');
+    if (!content.includes('flutter_ohos')) {
+      const overrides = `  "overrides": {\n    "@ohos/flutter_ohos": "file:third_party/flutter_embedding_debug_patched.har",\n    "flutter_native_arm64_v8a": "file:third_party/arm64_v8a_debug.har"\n  },`;
+      const newContent = content.replace('"dependencies":', overrides + '\n  "dependencies":');
+      fs.writeFileSync(ohPackagePath, newContent);
+    }
+  }
+}
+
 export class FlutterHvigorPlugin implements IPlugin {
   apply(appContext: ProjectContext) {
     // Apply the override injection
     injectOverrides(appContext);
     
